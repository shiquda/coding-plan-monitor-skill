# Coding Plan Monitor 配置文件
# 复制此文件为 .env 并填入你的 Token

# ============================================
# MiniMax Coding Plan
# ============================================
# 1. 登录 https://www.minimaxi.com/
# 2. 进入 Coding Plan 页面
# 3. F12 打开开发者工具 → Network
# 4. 刷新页面，找到 /coding_plan/remains 请求
# 5. 复制 Request Headers 里的 Authorization 值（去掉 "Bearer " 前缀）
MINIMAX_CODING_API_KEY=your_minimax_api_key_here

# ============================================
# RightCode
# ============================================
# 1. 登录 https://right.codes/
# 2. F12 打开开发者工具 → Network
# 3. 刷新页面，找到 /subscriptions/list 请求
# 4. 复制 Request Headers 里的 Authorization 值（去掉 "Bearer " 前缀）
RIGHTCODE_TOKEN=your_rightcode_token_here

# ============================================
# Kimi Coding Plan (可选)
# ============================================
# 注意：Kimi 的 Bearer Token 有效期很短（几分钟），不适合长期监控
# 如果要使用，需要频繁更新 Token
#
# 获取方式：
# 1. 登录 https://www.kimi.com/code/console
# 2. F12 打开开发者工具 → Network
# 3. 刷新页面，找到 GetUsages 请求
# 4. 复制 Request Headers 里的 authorization 值（去掉 "Bearer " 前缀）
KIMI_BEARER_TOKEN=your_kimi_bearer_token_here
